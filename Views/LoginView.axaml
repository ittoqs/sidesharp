<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SIDESA.Net.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SIDESA.Net.Views.LoginView"
             x:DataType="vm:LoginViewModel">

    <Grid Background="#f8fafc">
        <Border Background="White" 
                CornerRadius="10" 
                Padding="40" 
                Width="400" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                BoxShadow="0 4 10 0 #20000000">
            <StackPanel Spacing="15">
                <TextBlock Text="SI-DESAKU" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#0f172a" Margin="0,0,0,5"/>
                <TextBlock Text="Silakan login untuk melanjutkan" FontSize="14" HorizontalAlignment="Center" Foreground="#64748b" Margin="0,0,0,20"/>

                <TextBlock Text="Username" FontWeight="SemiBold" Foreground="#334155"/>
                <TextBox Text="{Binding Username}" Watermark="Masukkan username" />

                <TextBlock Text="Password" FontWeight="SemiBold" Foreground="#334155"/>
                <TextBox Text="{Binding Password}" Watermark="Masukkan password" PasswordChar="•" />

                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                <Button Content="MASUK" Command="{Binding LoginCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#0ea5e9" Foreground="White" FontWeight="Bold" Padding="10" Margin="0,15,0,0" CornerRadius="5"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
