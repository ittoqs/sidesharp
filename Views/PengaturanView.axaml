<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SIDESA.Net.ViewModels"
             x:Class="SIDESA.Net.Views.PengaturanView"
             x:DataType="vm:PengaturanViewModel">

    <ScrollViewer>
        <Border Background="White" CornerRadius="8" Padding="30" Margin="20" BoxShadow="0 4 10 0 #1A000000">
            <StackPanel Spacing="20">
                <TextBlock Text="Profil Instansi (Desa/Kelurahan)" FontSize="18" FontWeight="Bold"/>
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" Margin="0,10">
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Nama Desa" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Desa}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Kecamatan" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Kecamatan}"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Kabupaten" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Kabupaten}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Provinsi" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Provinsi}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Alamat Lengkap" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Alamat}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,15">
                        <TextBlock Text="Nomor Telepon" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding Telepon}"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,10"/>
                
                <TextBlock Text="Penandatangan Surat" FontSize="18" FontWeight="Bold"/>
                <Grid ColumnDefinitions="*, *, *" RowDefinitions="Auto" Margin="0,10">
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,15">
                        <TextBlock Text="Nama Kades" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NamaKades}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="5,0,5,15">
                        <TextBlock Text="NIP (Kosongkan jika tidak ada)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding NipKades}"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,15">
                        <TextBlock Text="Jabatan" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding JabatanKades}"/>
                    </StackPanel>
                </Grid>

                <Button Content="Simpan Pengaturan" Command="{Binding SaveConfigCommand}" Background="#3b82f6" Foreground="White" FontWeight="Bold" FontSize="14" Padding="20,10" HorizontalAlignment="Right" Margin="0,20,0,0" CornerRadius="8"/>
            </StackPanel>
        </Border>
    </ScrollViewer>

</UserControl>
