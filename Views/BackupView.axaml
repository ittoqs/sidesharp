<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SIDESA.Net.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SIDESA.Net.Views.BackupView"
             x:DataType="vm:BackupViewModel">

    <Grid>
        <StackPanel Margin="40" Spacing="20">
            <TextBlock Text="Backup Data Sistem" FontSize="24" FontWeight="Bold" Foreground="#334155"/>
            <TextBlock Text="Fitur ini akan menyalin database (surat.db) dan pengaturan (config.json) ke folder tujuan yang Anda pilih. Sangat disarankan untuk rutin melakukan backup." TextWrapping="Wrap" Foreground="#64748b"/>
            
            <Border Background="#fffbeb" BorderBrush="#f59e0b" BorderThickness="1" CornerRadius="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="PERHATIAN" FontWeight="Bold" Foreground="#d97706"/>
                    <TextBlock Text="Untuk Restore (mengembalikan data), Anda harus menyalin manual file backup ke dalam folder aplikasi, lalu merestart aplikasi SI-DESAKU agar data dapat dimuat ulang secara aman." TextWrapping="Wrap" Foreground="#d97706" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Button x:Name="BtnPilihFolder" Content="Pilih Folder &amp; Mulai Backup" Background="#10b981" Foreground="White" FontWeight="Bold" Padding="20,10" CornerRadius="5" HorizontalAlignment="Left" Click="BtnPilihFolder_Click"/>

            <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="#0f172a" Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</UserControl>
