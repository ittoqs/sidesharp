<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SIDESA.Net.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SIDESA.Net.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">
            <!-- Cards Row -->
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <!-- Card 1 -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000" BorderLeftBrush="#3b82f6" BorderThickness="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL PENDUDUK" FontSize="12" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalPenduduk}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Card 2 -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000" BorderLeftBrush="#10b981" BorderThickness="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="SURAT HARI INI" FontSize="12" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SuratHariIni}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Card 3 -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000" BorderLeftBrush="#f59e0b" BorderThickness="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="SURAT BULAN INI" FontSize="12" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Text="{Binding SuratBulanIni}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                <!-- Card 4 -->
                <Border Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000" BorderLeftBrush="#8b5cf6" BorderThickness="5,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TEMPLATE AKTIF" FontSize="12" Foreground="Gray" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TemplateAktif}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid ColumnDefinitions="3*, 2*">
                <!-- Recent Letters Table -->
                <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000">
                    <StackPanel>
                        <TextBlock Text="Surat Terbaru" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <DataGrid ItemsSource="{Binding RecentLetters}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="No. Surat" Binding="{Binding Nomor_Surat}"/>
                                <DataGridTextColumn Header="Tanggal" Binding="{Binding Tanggal}"/>
                                <DataGridTextColumn Header="Nama Penerima" Binding="{Binding Nama}"/>
                                <DataGridTextColumn Header="Jenis Surat" Binding="{Binding Jenis_Surat}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
                
                <!-- Chart Placeholder -->
                <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="20" Margin="10" BoxShadow="0 4 10 0 #1A000000">
                    <StackPanel>
                        <TextBlock Text="Distribusi Surat" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                        <TextBlock Text="Data distribusi surat akan ditampilkan di sini." Foreground="Gray" FontStyle="Italic"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
